# -----------------------------------------------------------------------------
# Nexus Core — self-hosted per organisation
# -----------------------------------------------------------------------------
# If a vendor (e.g. Spring 2) hosts the app for a client, the vendor sets these
# variables in Railway/hosting — the client normally never sees this file.
# See README → "Vendor-managed clients".
#
# Each deployment is isolated: your own hosting, SQLite/volume, Supabase project,
# OAuth apps, and secrets. Nothing points at another organisation’s machines.
# Copy this file to .env and copy client/.env.example to client/.env for the SPA.
# Generate SESSION_SECRET: npm run deploy:gen-secret
# Production: set OAUTH_PUBLIC_URL and FRONTEND_ORIGIN to your public HTTPS URLs
# (same host as the app if API + UI are one service, or your SPA origin if split).
# -----------------------------------------------------------------------------

# Database (path is resolved from the repo root unless you pass an absolute path)
DATABASE_PATH=./data/schedule.db

# Persistent disk (e.g. Railway volume)
# 1. In Railway: add a Volume to this service and set "Mount Path" to /data (or any path you prefer).
# 2. Set both variables below to that same mount so SQLite and uploads survive redeploys.
#    Example when the volume is mounted at /data:
# DATA_DIR=/data
# DATABASE_PATH=/data/schedule.db
# DATA_DIR controls ./data-style dirs for uploads; DATABASE_PATH must point at the SQLite file (can be absolute).

# --- Nexus Core Supabase (this repo’s Postgres: public.profiles, organizations, shifts, etc.) ---
# Dashboard → Project Settings → API: Project URL + service_role (server only; never expose to the browser).
# With these set, creating/editing staff with an email provisions Auth + public.profiles (shifter_enabled false until you enable in Staff UI).
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# JWT secret (Dashboard → Project Settings → API → JWT Secret). Required to verify browser access tokens for /api/auth/supabase/session.
# SUPABASE_JWT_SECRET=
#
# Vite client — REQUIRED for Supabase sign-in / org features in the browser (same project as above):
# Dashboard → Project Settings → API: Project URL + anon public key (not service_role).
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Optional: keep VITE_* for org/Shifter features but sign in with SQLite (local users table).
# VITE_PREFER_LOCAL_LOGIN=true

# --- Shifter Supabase (separate project: worker app) ---
# Same project URL + service_role as Edge Function secrets (push-shift-to-shifter).
# Used by Nexus server to verify workers and to pull org-scoped shifts via POST /api/sync/from-shifter.
SHIFTER_SUPABASE_URL=
SHIFTER_SERVICE_ROLE_KEY=

# Super admin (comma-separated Nexus login emails) — Feature flags matrix in Admin; keep server-only.
# NEXUS_SUPER_ADMIN_EMAILS=you@company.com
#
# Optional: Database Webhook header x-webhook-secret must match if set (shift push)
# SHIFT_PUSH_WEBHOOK_SECRET=

# Mirror SQLite shifts → Nexus Supabase public.shifts (Shifter pipeline). On-change mirror is automatic.
# Optional: periodic full re-mirror (ms, min 60000). Cron alternative: POST /api/sync/nexus-public-shifts with CRM_API_KEY.
# NEXUS_PUBLIC_SHIFTS_SYNC_INTERVAL_MS=900000
# NEXUS_PUBLIC_SHIFTS_SYNC_ON_START=true

# Progress Notes App – shared secret for webhook / Excel sync. With SHIFTER_* set, Link to Shifter tries to write this + webhook URL into Shifter public.organizations.
CRM_API_KEY=

# --- OneDrive Excel pull (Progress Notes / Schedule Shift workbook) ---
# Without Settings → Connect Microsoft for documents, the server uses an Entra “application” (client credentials)
# to read one user’s OneDrive. Check these on the API host (.env or platform secrets), then restart the server.
#
#   [ ] AZURE_TENANT_ID       — Entra ID → Overview → Directory (tenant) ID
#   [ ] AZURE_CLIENT_ID       — App registration → Application (client) ID
#   [ ] AZURE_CLIENT_SECRET   — App registration → Certificates & secrets → Value (not Secret ID)
#   [ ] ONEDRIVE_ADMIN_USER_ID — Microsoft 365 sign-in email of the account that OWNS the Excel file (UPN), e.g. admin@yourtenant.onmicrosoft.com
#                                Alias: ADMIN_USER_ID (same value). Graph calls /users/{this email}/drive/...
#   [ ] ONEDRIVE_EXCEL_PATH   — Path under that user’s OneDrive, slash-separated (optional; default below).
#                               If SHIFTER_SUPABASE_URL + SHIFTER_SERVICE_ROLE_KEY are set, Nexus prefers the path from
#                               Shifter public.profiles (Org Admin): progress_notes_onedrive_path or progress_notes_folder + progress_notes_filename (see supabase/shifter-migrations).
#
# Entra app: Application permission Files.Read.All (not delegated) + admin consent.
# If all Azure vars are set but ONEDRIVE_ADMIN_USER_ID is missing, Excel pull fails with “ONEDRIVE_ADMIN_USER_ID is required”.
# Docker/Fly/Railway: set the same keys as host secrets — they are not baked into the image.
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# ONEDRIVE_ADMIN_USER_ID=
# ONEDRIVE_EXCEL_PATH=Progress Notes App/master progress notes.xlsx

# Xero OAuth – browser redirect after Xero login (SPA origin with /settings). Required if API host ≠ UI host.
# Local dev: set to http://localhost:5174 if not using default Vite port, or rely on auto :3080 → :5174 when NODE_ENV is not production.
# FRONTEND_BASE_URL=
# VITE_DEV_PORT=5174
# Local Xero: if the developer portal only allows https redirect URIs, enable Vite TLS (self-signed) and use https://localhost:5174/... in Xero + Nexus.
# Open the app at https://localhost:5174 when this is true (accept the self-signed cert once). Session cookies stay non-Secure in dev so http:// still works if you toggle this off.
# VITE_DEV_HTTPS=true
#
# One Nexus Xero app for all orgs (Settings shows “Connect to Xero” only). Add the same redirect URI in the Xero developer portal.
# These must be on the API server (this file / host env), not in client/.env.
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=https://your-api-host/api/settings/xero-callback
# If OAUTH_PUBLIC_URL is already set (below), you may omit XERO_REDIRECT_URI — Nexus uses OAUTH_PUBLIC_URL + /api/settings/xero-callback.
# Optional override for authorize URL scopes (default uses granular scopes for apps created Mar 2026+)
# XERO_OAUTH_SCOPES=
#
# Xero sales invoice lines (batch send from Financial → Invoice Batches). Use codes from your Xero chart of accounts / tax rates.
# XERO_SALES_ACCOUNT_CODE=200
# XERO_LINE_TAX_TYPE_GST=OUTPUT
# XERO_LINE_TAX_TYPE_EXEMPT=BASEXCLUDED

# Auth (sessions; also encrypts stored OAuth refresh tokens for email sending)
# Production: must be 32+ random characters (the server exits on startup if unset or too weak).
SESSION_SECRET=change-this-to-a-long-random-string-min-32-chars
SMTP_ENCRYPTION_KEY=optional-separate-key-for-encrypting-oauth-tokens
# Emergency account recovery (disabled by default).
# Set to true only long enough to run one emergency login, then set back to false and rotate token.
# NEXUS_ENABLE_EMERGENCY_LOGIN=false
# NEXUS_EMERGENCY_LOGIN_TOKEN=generate-a-long-random-token

# --- Email sending (OAuth + Azure Function relay) ---
# Nexus does not use classic SMTP host/user/password in this file for roster/notification mail.
# "Nexus Core domain" for OAuth = the public origin of THIS API (same value as OAUTH_PUBLIC_URL).
# Supabase sign-up / password-reset emails are separate: configure Custom SMTP in Supabase Dashboard → Authentication (not here).
# 1. Deploy azure-email-function and set its URL here (must include /api/sendEmail or base host).
# Must be your Azure Function URL (…azurewebsites.net/…/sendEmail), NOT your Fly or CRM public URL — otherwise the server calls itself and you get "Not authenticated".
# If test email returns "Not authenticated" with a correct Azure URL: Azure Portal → Function app → Authentication → allow unauthenticated access (or disable). Query strings (e.g. ?code=) are preserved.
# Replace YOURAPP with your real Function app name (Azure Portal → Function app → Overview). You may paste host without https:// — the server adds it.
AZURE_EMAIL_FUNCTION_URL=https://YOURAPP.azurewebsites.net/api/sendEmail
# Optional; must match API_KEY in the Function app settings if you set one there.
# AZURE_EMAIL_API_KEY=

# 2. Google Cloud: OAuth client (Gmail API enabled). Redirect URI must be:
#    {OAUTH_PUBLIC_URL}/api/email/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 3. Azure AD app registration: delegated Mail.Send + (optional) Files.ReadWrite.All for org document archive.
#    Email redirect: {OAUTH_PUBLIC_URL}/api/email/oauth/microsoft/callback
#    OneDrive (per org): {OAUTH_PUBLIC_URL}/api/integrations/microsoft-drive/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
# Use "common" for work + personal Microsoft accounts, or your tenant ID for single-tenant.
MICROSOFT_OAUTH_TENANT=common

# Public origin of this API only (scheme + host + port). Do NOT paste the full callback path here —
# the server appends /api/email/oauth/... and /api/integrations/microsoft-drive/callback itself.
# Dev example: http://localhost:3001   Production: https://your-api.fly.dev
OAUTH_PUBLIC_URL=http://localhost:3001
# Optional: public API origin for shift webhook/sync URLs (Settings) when Supabase Admin profile nexus_shift_api_base_url is unset. Falls back to OAUTH_PUBLIC_URL then FRONTEND_BASE_URL.
# NEXUS_PUBLIC_API_URL=
# Where to send users after OAuth (usually your SPA). Dev with Vite: http://localhost:5173
FRONTEND_ORIGIN=http://localhost:5173

# AI (Ollama only - privacy by design)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
AI_ENABLED=true
# Excel Shifts sync: set true to always run Ollama for column mapping (slower; default runs only when key columns are missing)
EXCEL_SHIFTS_LLM_ENRICH=false

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Company/Invoice defaults (used for billing PDF layout)
COMPANY_NAME=Your organisation name
COMPANY_ABN=
COMPANY_EMAIL=
COMPANY_REGISTRATION=
COMPANY_BSB=
COMPANY_ACCOUNT=
PAYMENT_TERMS_DAYS=7

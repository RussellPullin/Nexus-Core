# Copy this file to client/.env — Vite only reads env from client/, not the repo root.
# Each organisation uses its own Supabase project and keys (never reuse another tenant’s project).

# true = SQLite email/password login even when Supabase URL/anon key are set
VITE_PREFER_LOCAL_LOGIN=false

# Same Supabase project as in root .env (anon / public key only — never service_role)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run deploy:build"
  },
  "deploy": {
    "startCommand": "npm run deploy:start",
    "healthcheckPath": "/api/auth/ping",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
